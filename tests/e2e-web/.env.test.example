# Copy this to .env.test and fill in values. Never commit .env.test.
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Stable seed user credentials (from supabase/seed.sql)
TEST_ADMIN_EMAIL=admin@adtruck.com
TEST_ADMIN_PASSWORD=your-admin-password
TEST_CLIENT_EMAIL=client@acme.com
TEST_CLIENT_PASSWORD=your-client-password
TEST_DRIVER_USERNAME=driver1
TEST_DRIVER_PASSWORD=your-driver-password

# Seed campaign ID (from supabase/seed.sql)
TEST_CAMPAIGN_ID=00000000-0000-0000-0000-000000000010

BASE_URL=http://localhost:5173
